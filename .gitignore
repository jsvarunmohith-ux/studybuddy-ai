# .gitignore for StudyBuddy AI (pure HTML/JS project)
# ---------------------------------------------------
# Node / npm build artifacts (if you ever add a build step)
node_modules/
.dist/
.cache/
# Build output directories (e.g., Vite, Webpack)
build/
# IDE / editor settings
.vscode/
*.sublime-workspace
*.sublime-project
# OS‑specific files
.DS_Store
Thumbs.db
# Logs & temporary files
npm-debug.log
yarn-debug.log
yarn-error.log
*.log
# Environment files
.env
# Optional: ignore screenshots if you store them elsewhere
# screenshots/
